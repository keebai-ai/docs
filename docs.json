      },
      {
        "tab": "Webhooks",
        "icon": "bell",
        "openapi": {
          "source": "https://api.keebai.com/v1/docs-json",
          "directory": "_openapi/webhooks"
        },
        "groups": [
          {
            "group": "Empezar",
            "pages": [
              "dev/webhooks/overview",
              "dev/webhooks/cli"
