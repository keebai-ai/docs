{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "KeebAI",
  "colors": {
    "primary": "#FF73C2",
    "light": "#FF73C2",
    "dark": "#FF73C2"
  },
  "appearance": {
    "default": "light"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Soporte",
        "href": "mailto:support@keebai.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Ir a Keebai",
      "href": "https://app.keebai.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Inicio",
            "pages": [
              "index",
              "get-started",
              "dashboard/overview",
              "embudo/overview"
            ]
          },
          {
            "group": "Chat",
            "pages": [
              "chat/overview"
            ]
          },
          {
            "group": "IA & Asistentes",
            "pages": [
              "ia-asistentes/mis-asistentes",
              "ia-asistentes/mis-conocimientos",
              "ia-asistentes/integraciones",
              "ia-asistentes/mis-funciones"
            ]
          },
          {
            "group": "Canales",
            "pages": [
              "canales/mis-canales",
              "canales/webchat",
              "canales/difusion-masiva",
              "canales/templates",
              "canales/flows"
            ]
          },
          {
            "group": "CRM",
            "pages": [
              "crm/pipelines",
              "crm/tickets",
              "crm/clientes",
              "crm/fusionar-contactos",
              "crm/tareas",
              "crm/campos",
              "crm/tags",
              "crm/configurar-ticket",
              "crm/lead-ads"
            ]
          },
          {
            "group": "Configuraciones",
            "pages": [
              "configuraciones/overview"
            ]
          }
        ]
      },
      {
        "tab": "Autenticación",
        "icon": "shield-check",
        "openapi": {
          "source": "https://api.keebai.com/v1/docs-json",
          "directory": "_openapi/auth"
        },
        "groups": [
          {
            "group": "Empezar",
            "pages": [
              "dev/overview",
              "dev/quickstart"
            ]
          },
          {
            "group": "Tokens",
            "pages": [
              "dev/api-keys",
              "dev/authentication",
              "dev/scopes"
            ]
          },
          {
            "group": "Sesión actual",
            "pages": [
              "dev/endpoints/me"
            ]
          },
          {
            "group": "Operación",
            "pages": [
              "dev/rate-limits"
            ]
          }
        ]
      },
      {
        "tab": "Messaging",
        "icon": "paper-plane",
        "openapi": {
          "source": "https://api.keebai.com/v1/docs-json",
          "directory": "_openapi/messaging"
        },
        "groups": [
          {
            "group": "WhatsApp",
            "pages": [
              "dev/endpoints/messages-template",
              "dev/endpoints/messages-text",
              "dev/endpoints/messages-bulk",
              "dev/endpoints/messages-bulk-status"
            ]
          },
          {
            "group": "Templates",
            "pages": [
              "dev/endpoints/templates-list",
              "dev/endpoints/templates-create",
              "dev/endpoints/templates-update"
            ]
          },
          {
            "group": "Canales",
            "pages": [
              "dev/endpoints/channels-list",
              "dev/endpoints/whatsapp-numbers",
              "dev/endpoints/channels-whatsapp-connect",
              "dev/endpoints/channels-whatsapp-connect-qr"
