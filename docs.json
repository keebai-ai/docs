      {
        "tab": "Conocimiento",
        "icon": "book-bookmark",
        "openapi": {
          "source": "https://api.keebai.com/v1/docs-json",
          "directory": "_openapi/knowledge"
        },
        "groups": [
          {
            "group": "Base de conocimientos",
            "pages": [
              "dev/endpoints/knowledge-tree",
              "dev/endpoints/knowledge-folder-create",
              "dev/endpoints/knowledge-document-create",
